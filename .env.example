# ===== LLM 配置 =====
# 智谱 AI API Key（从 https://open.bigmodel.cn/ 获取）
LLM_API_KEY=your_api_key_here
# API 基础地址（智谱 AI 默认地址）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 默认使用的模型
LLM_MODEL=glm-5-turbo

# ===== LLM 备用配置（主Key失效时自动切换）=====
LLM_API_KEY_BACKUP=your_backup_api_key_here
LLM_BASE_URL_BACKUP=https://open.bigmodel.cn/api/paas/v4

# ===== Embedding 模型配置 =====
# Embedding 提供者：local（本地免费）或 openai（云端API）
EMBEDDING_PROVIDER=local
# 本地 Embedding 模型名称
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 云端 Embedding 模型名称（EMBEDDING_PROVIDER=openai 时使用）
EMBEDDING_MODEL=embedding-3
# [#12] Embedding 独立 API Key（如未设置则复用 LLM_API_KEY）
EMBEDDING_API_KEY=your_embedding_api_key_here
# Embedding API Base URL（如未设置则复用 LLM_BASE_URL）
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ===== 应用配置 =====
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== 外部系统集成（可选）=====
# GitHub Token（用于 GitHub API 工具）
GITHUB_TOKEN=
# SMTP 邮件配置（用于发送邮件工具）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# 数据库连接（用于数据库查询工具）
DATABASE_URL=

# DeepSeek 独立配置（火山引擎 Ark，如不填则复用 LLM_API_KEY/LLM_BASE_URL）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
