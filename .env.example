# ===== LLM 配置 =====
# 智谱 AI API Key（从 https://open.bigmodel.cn/ 获取）
LLM_API_KEY=your_api_key_here
# API 基础地址（智谱 AI 默认地址）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 默认使用的模型
LLM_MODEL=glm-5.1

# ===== LLM 备用配置（主Key失效时自动切换）=====
LLM_API_KEY_BACKUP=your_backup_api_key_here
LLM_BASE_URL_BACKUP=https://open.bigmodel.cn/api/paas/v4

# ===== Embedding 模型配置 =====
# Embedding 提供者：local（本地免费）或 openai（云端API）
EMBEDDING_PROVIDER=local
# 本地 Embedding 模型名称
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 云端 Embedding 模型名称（EMBEDDING_PROVIDER=openai 时使用）
EMBEDDING_MODEL=embedding-3
# [#12] Embedding 独立 API Key（如未设置则复用 LLM_API_KEY）
EMBEDDING_API_KEY=your_embedding_api_key_here
# Embedding API Base URL（如未设置则复用 LLM_BASE_URL）
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ===== 应用配置 =====
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== 外部系统集成（可选）=====
# GitHub Token（用于 GitHub API 工具）
GITHUB_TOKEN=
# SMTP 邮件配置（用于发送邮件工具）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# 数据库连接（用于数据库查询工具）
DATABASE_URL=

# ===== 火山引擎（豆包/DeepSeek）独立配置 =====
# 豆包/DeepSeek 共用此配置，走火山引擎 Ark Coding API
# ⚠️ 重要：必须使用 /api/coding/v3 而非 /api/v3，后者会产生额外费用！
# 兼容 OpenAI 接口协议：https://ark.cn-beijing.volces.com/api/coding/v3
# 兼容 Anthropic 接口协议：https://ark.cn-beijing.volces.com/api/coding
# 模型 ark-code-latest 为 Auto 模式，自动选择最优模型
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ===== 千问独立配置（阿里云 DashScope）=====
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== MiMo独立配置（小米）=====
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# ===== 视觉模型专用配置（智谱AI）=====
# 无论当前选用什么模型（DeepSeek/豆包/千问/MiMo），上传图片时始终走智谱AI视觉模型
# 如未设置则回退到 LLM_API_KEY / LLM_BASE_URL
VISION_API_KEY=
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
